# ── SERVER ───────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── DATABASE ─────────────────────────────────────
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=trasenhong

# ── JWT ───────────────────────────────────────────
JWT_SECRET=your_random_secret_min_32_chars

# ── GHN API ───────────────────────────────────────
GHN_TOKEN=your_ghn_token
GHN_SHOP_ID=your_shop_id
GHN_FROM_DISTRICT_ID=1929

# ── EMAILJS ───────────────────────────────────────
# Lấy tại: https://dashboard.emailjs.com
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
EMAILJS_ORDER_TEMPLATE_ID=your_order_template_id
EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id

# ── FRONTEND ──────────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com
